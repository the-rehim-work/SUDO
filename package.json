{
  "name": "sudo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "echo \"No tests configured\"",
    "setup": "dotenv -e .env.local -- prisma generate && dotenv -e .env.local -- prisma migrate deploy",
    "dev": "npm run setup && next dev",
    "build": "dotenv -e .env.local -- prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "dotenv -e .env.local -- prisma generate",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "prisma:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "prisma:studio": "dotenv -e .env.local -- prisma studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-rehim-work/SUDO.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/the-rehim-work/SUDO/issues"
  },
  "homepage": "https://github.com/the-rehim-work/SUDO#readme",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "next": "^16.2.3",
    "prisma": "^6.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}